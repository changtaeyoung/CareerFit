<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.careerfit.backend.domain.company.mapper.CompanyMapper">

    <!-- =====================================================
         ResultMap
    ====================================================== -->
    <resultMap id="CompanyResultMap" type="com.careerfit.backend.domain.company.entity.Company">
        <id     property="id"               column="id"/>
        <result property="dartCode"         column="dart_code"/>
        <result property="alioCode"         column="alio_code"/>
        <result property="name"             column="name"/>
        <result property="industry"         column="industry"/>
        <result property="companyType"      column="company_type"/>
        <result property="location"         column="location"/>
        <result property="website"          column="website"/>
        <result property="employeeCount"    column="employee_count"/>
        <result property="foundedYear"      column="founded_year"/>
        <result property="isPublic"         column="is_public"/>
        <result property="vision"           column="vision"/>
        <result property="talentImage"      column="talent_image"/>
        <result property="businessOverview" column="business_overview"/>
        <result property="createdAt"        column="created_at"/>
        <result property="updatedAt"        column="updated_at"/>
    </resultMap>

    <resultMap id="JobPostingResponseMap" type="com.careerfit.backend.domain.company.dto.JobPostingResponse">
        <id     property="id"          column="id"/>
        <result property="companyId"   column="company_id"/>
        <result property="companyName" column="company_name"/>
        <result property="title"       column="title"/>
        <result property="url"         column="url"/>
        <result property="status"      column="status"/>
        <result property="jobType"     column="job_type"/>
        <result property="season"      column="season"/>
        <result property="startedAt"   column="started_at"/>
        <result property="deadline"    column="deadline"/>
    </resultMap>

    <!-- =====================================================
         기업 목록 조회 (페이징 + 필터 + 키워드 검색)
    ====================================================== -->
    <select id="selectCompanyList" resultMap="CompanyResultMap">
        SELECT *
        FROM company
        <where>
            <if test="industry != null and industry != ''">
                AND industry = #{industry}
            </if>
            <if test="companyType != null and companyType != ''">
                AND company_type = #{companyType}
            </if>
            <if test="keyword != null and keyword != ''">
                AND name LIKE CONCAT('%', #{keyword}, '%')
            </if>
        </where>
        ORDER BY name ASC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <!-- 기업 목록 전체 건수 (totalPages 계산용, selectCompanyList와 동일 WHERE 조건) -->
    <select id="countCompanyList" resultType="int">
        SELECT COUNT(*)
        FROM company
        <where>
            <if test="industry != null and industry != ''">
                AND industry = #{industry}
            </if>
            <if test="companyType != null and companyType != ''">
                AND company_type = #{companyType}
            </if>
            <if test="keyword != null and keyword != ''">
                AND name LIKE CONCAT('%', #{keyword}, '%')
            </if>
        </where>
    </select>

    <!-- =====================================================
         기업 상세 조회
    ====================================================== -->
    <select id="selectCompanyById" resultMap="CompanyResultMap">
        SELECT *
        FROM company
        WHERE id = #{id}
    </select>

    <!-- =====================================================
         기업별 채용공고 목록
    ====================================================== -->
    <select id="selectPostingsByCompanyId" resultMap="JobPostingResponseMap">
        SELECT jp.id,
               jp.company_id,
               c.name AS company_name,
               jp.title,
               jp.url,
               jp.status,
               jp.job_type,
               jp.season,
               jp.started_at,
               jp.deadline
        FROM job_posting jp
                 JOIN company c ON jp.company_id = c.id
        WHERE jp.company_id = #{companyId}
        ORDER BY jp.created_at DESC
    </select>

    <!-- =====================================================
         전체 채용공고 목록 (페이징 + 직무/상태/키워드 필터)
    ====================================================== -->
    <select id="selectPostings" resultMap="JobPostingResponseMap">
        SELECT jp.id,
               jp.company_id,
               c.name AS company_name,
               jp.title,
               jp.url,
               jp.status,
               jp.job_type,
               jp.season,
               jp.started_at,
               jp.deadline
        FROM job_posting jp
                 JOIN company c ON jp.company_id = c.id
        <where>
            <if test="status != null and status != ''">
                AND jp.status = #{status}
            </if>
            <if test="jobType != null and jobType != ''">
                AND jp.job_type = #{jobType}
            </if>
            <if test="keyword != null and keyword != ''">
                AND (jp.title LIKE CONCAT('%', #{keyword}, '%')
                    OR c.name  LIKE CONCAT('%', #{keyword}, '%'))
            </if>
        </where>
        ORDER BY jp.created_at DESC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <!-- 채용공고 전체 건수 (totalPages 계산용, selectPostings와 동일 WHERE 조건) -->
    <select id="countPostings" resultType="int">
        SELECT COUNT(*)
        FROM job_posting jp
                 JOIN company c ON jp.company_id = c.id
        <where>
            <if test="status != null and status != ''">
                AND jp.status = #{status}
            </if>
            <if test="jobType != null and jobType != ''">
                AND jp.job_type = #{jobType}
            </if>
            <if test="keyword != null and keyword != ''">
                AND (jp.title LIKE CONCAT('%', #{keyword}, '%')
                    OR c.name  LIKE CONCAT('%', #{keyword}, '%'))
            </if>
        </where>
    </select>

    <!-- DART 동기화용 쿼리
    ====================================================== -->

    <!-- dart_code가 없는(NULL) 기업 전체 조회 — 동기화 대상 선별 -->
    <select id="selectCompaniesWithoutDartCode" resultMap="CompanyResultMap">
        SELECT *
        FROM company
        WHERE dart_code IS NULL
        ORDER BY id ASC
    </select>

    <!-- dart_code가 있는 기업만 조회 — empSttus 연봉 수집 대상 -->
    <select id="selectCompaniesWithDartCode" resultMap="CompanyResultMap">
        SELECT *
        FROM company
        WHERE dart_code IS NOT NULL
        ORDER BY id ASC
    </select>

    <!-- =====================================================
         ALIO 동기화용 쿼리
    ====================================================== -->

    <!-- alio_code가 없는 기업 조회 — ALIO 동기화 대상 -->
    <select id="selectCompaniesWithoutAlioCode" resultMap="CompanyResultMap">
        SELECT *
        FROM company
        WHERE alio_code IS NULL
        ORDER BY id ASC
    </select>

    <!-- ALIO API 결과로 기관 정보 업데이트 -->
    <update id="updateAlioInfo">
        UPDATE company
        SET alio_code        = #{alioCode},
            employee_count   = COALESCE(#{employeeCount}, employee_count),
            founded_year     = COALESCE(#{foundedYear},   founded_year),
            business_overview= COALESCE(#{businessOverview}, business_overview),
            updated_at       = NOW()
        WHERE id = #{id}
    </update>

    <!-- Admin 수동 입력 — null 파라미터는 기존 값 유지 (COALESCE 패턴)
         인재상/비전처럼 자동화 불가한 정성적 정보를 관리자가 직접 입력할 때 사용.
         null인 필드는 기존 DB 값 그대로 유지 → PATCH 방식 구현. -->
    <update id="updateCompanyInfo">
        UPDATE company
        SET vision            = COALESCE(#{vision},           vision),
            talent_image      = COALESCE(#{talentImage},      talent_image),
            business_overview = COALESCE(#{businessOverview}, business_overview),
            employee_count    = COALESCE(#{employeeCount},    employee_count),
            founded_year      = COALESCE(#{foundedYear},      founded_year),
            website           = COALESCE(#{website},          website),
            location          = COALESCE(#{location},         location),
            updated_at        = NOW()
        WHERE id = #{id}
    </update>

    <!-- DART 매칭 결과로 dart_code 업데이트 -->
    <update id="updateDartCode">
        UPDATE company
        SET dart_code  = #{dartCode},
            updated_at = NOW()
        WHERE id = #{id}
    </update>

    <!-- =====================================================
         채용공고 상세 조회 (url 포함, JobPostingResponse 재사용)
    ====================================================== -->
    <select id="selectPostingById" resultMap="JobPostingResponseMap">
        SELECT jp.id,
               jp.company_id,
               c.name AS company_name,
               jp.title,
               jp.url,
               jp.status,
               jp.job_type,
               jp.season,
               jp.started_at,
               jp.deadline
        FROM job_posting jp
                 JOIN company c ON jp.company_id = c.id
        WHERE jp.id = #{id}
    </select>

</mapper>
