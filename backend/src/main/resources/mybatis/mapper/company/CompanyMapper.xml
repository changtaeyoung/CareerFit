<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.careerfit.backend.domain.company.mapper.CompanyMapper">

    <!-- =====================================================
         ResultMap
    ====================================================== -->
    <resultMap id="CompanyResultMap" type="com.careerfit.backend.domain.company.entity.Company">
        <id     property="id"               column="id"/>
        <result property="dartCode"         column="dart_code"/>
        <result property="alioCode"         column="alio_code"/>
        <result property="name"             column="name"/>
        <result property="industry"         column="industry"/>
        <result property="companyType"      column="company_type"/>
        <result property="location"         column="location"/>
        <result property="website"          column="website"/>
        <result property="employeeCount"    column="employee_count"/>
        <result property="foundedYear"      column="founded_year"/>
        <result property="isPublic"         column="is_public"/>
        <result property="vision"           column="vision"/>
        <result property="talentImage"      column="talent_image"/>
        <result property="businessOverview" column="business_overview"/>
        <result property="createdAt"        column="created_at"/>
        <result property="updatedAt"        column="updated_at"/>
    </resultMap>

    <resultMap id="JobPostingResponseMap" type="com.careerfit.backend.domain.company.dto.JobPostingResponse">
        <id     property="id"          column="id"/>
        <result property="companyId"   column="company_id"/>
        <result property="companyName" column="company_name"/>
        <result property="title"       column="title"/>
        <result property="url"         column="url"/>
        <result property="status"      column="status"/>
        <result property="jobType"     column="job_type"/>
        <result property="season"      column="season"/>
        <result property="startedAt"   column="started_at"/>
        <result property="deadline"    column="deadline"/>
    </resultMap>

    <!-- =====================================================
         기업 목록 조회 (페이징 + 필터 + 키워드 검색)
    ====================================================== -->
    <select id="selectCompanyList" resultMap="CompanyResultMap">
        SELECT *
        FROM company
        <where>
            <if test="industry != null and industry != ''">
                AND industry = #{industry}
            </if>
            <if test="companyType != null and companyType != ''">
                AND company_type = #{companyType}
            </if>
            <if test="keyword != null and keyword != ''">
                AND name LIKE CONCAT('%', #{keyword}, '%')
            </if>
        </where>
        ORDER BY name ASC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <!-- 기업 목록 전체 건수 (totalPages 계산용, selectCompanyList와 동일 WHERE 조건) -->
    <select id="countCompanyList" resultType="int">
        SELECT COUNT(*)
        FROM company
        <where>
            <if test="industry != null and industry != ''">
                AND industry = #{industry}
            </if>
            <if test="companyType != null and companyType != ''">
                AND company_type = #{companyType}
            </if>
            <if test="keyword != null and keyword != ''">
                AND name LIKE CONCAT('%', #{keyword}, '%')
            </if>
        </where>
    </select>

    <!-- =====================================================
         기업 상세 조회
    ====================================================== -->
    <select id="selectCompanyById" resultMap="CompanyResultMap">
        SELECT *
        FROM company
        WHERE id = #{id}
    </select>

    <!-- =====================================================
         기업별 채용공고 목록
    ====================================================== -->
    <select id="selectPostingsByCompanyId" resultMap="JobPostingResponseMap">
        SELECT jp.id,
               jp.company_id,
               c.name AS company_name,
               jp.title,
               jp.url,
               jp.status,
               jp.job_type,
               jp.season,
               jp.started_at,
               jp.deadline
        FROM job_posting jp
                 JOIN company c ON jp.company_id = c.id
        WHERE jp.company_id = #{companyId}
        ORDER BY jp.created_at DESC
    </select>

    <!-- =====================================================
         전체 채용공고 목록 (페이징 + 직무/상태/키워드 필터)
    ====================================================== -->
    <select id="selectPostings" resultMap="JobPostingResponseMap">
        SELECT jp.id,
               jp.company_id,
               c.name AS company_name,
               jp.title,
               jp.url,
               jp.status,
               jp.job_type,
               jp.season,
               jp.started_at,
               jp.deadline
        FROM job_posting jp
                 JOIN company c ON jp.company_id = c.id
        <where>
            <if test="status != null and status != ''">
                AND jp.status = #{status}
            </if>
            <if test="jobType != null and jobType != ''">
                AND jp.job_type = #{jobType}
            </if>
            <if test="keyword != null and keyword != ''">
                AND (jp.title LIKE CONCAT('%', #{keyword}, '%')
                    OR c.name  LIKE CONCAT('%', #{keyword}, '%'))
            </if>
        </where>
        ORDER BY jp.created_at DESC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <!-- 채용공고 전체 건수 (totalPages 계산용, selectPostings와 동일 WHERE 조건) -->
    <select id="countPostings" resultType="int">
        SELECT COUNT(*)
        FROM job_posting jp
                 JOIN company c ON jp.company_id = c.id
        <where>
            <if test="status != null and status != ''">
                AND jp.status = #{status}
            </if>
            <if test="jobType != null and jobType != ''">
                AND jp.job_type = #{jobType}
            </if>
            <if test="keyword != null and keyword != ''">
                AND (jp.title LIKE CONCAT('%', #{keyword}, '%')
                    OR c.name  LIKE CONCAT('%', #{keyword}, '%'))
            </if>
        </where>
    </select>

    <!-- =====================================================
         채용공고 상세 조회 (url 포함, JobPostingResponse 재사용)
    ====================================================== -->
    <select id="selectPostingById" resultMap="JobPostingResponseMap">
        SELECT jp.id,
               jp.company_id,
               c.name AS company_name,
               jp.title,
               jp.url,
               jp.status,
               jp.job_type,
               jp.season,
               jp.started_at,
               jp.deadline
        FROM job_posting jp
                 JOIN company c ON jp.company_id = c.id
        WHERE jp.id = #{id}
    </select>

</mapper>
