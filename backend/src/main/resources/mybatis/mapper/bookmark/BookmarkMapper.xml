<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.careerfit.backend.domain.bookmark.mapper.BookmarkMapper">

    <!-- =====================================================
         ResultMap
    ====================================================== -->
    <resultMap id="BookmarkResultMap" type="com.careerfit.backend.domain.bookmark.entity.Bookmark">
        <id     property="id"          column="id"/>
        <result property="userId"      column="user_id"/>
        <result property="targetType"  column="target_type"/>
        <result property="companyId"   column="company_id"/>
        <result property="postingId"   column="posting_id"/>
        <result property="createdAt"   column="created_at"/>
    </resultMap>

    <resultMap id="BookmarkResponseMap" type="com.careerfit.backend.domain.bookmark.dto.BookmarkResponse">
        <id     property="id"            column="id"/>
        <result property="targetType"    column="target_type"/>
        <result property="companyId"     column="company_id"/>
        <result property="companyName"   column="company_name"/>
        <result property="postingId"     column="posting_id"/>
        <result property="postingTitle"  column="posting_title"/>
        <result property="deadline"      column="deadline"/>
        <result property="createdAt"     column="created_at"/>
    </resultMap>

    <!-- =====================================================
         북마크 등록 (useGeneratedKeys)
    ====================================================== -->
    <insert id="insertBookmark"
            parameterType="com.careerfit.backend.domain.bookmark.entity.Bookmark"
            useGeneratedKeys="true"
            keyProperty="id">
        INSERT INTO bookmark (user_id, target_type, company_id, posting_id, created_at)
        VALUES (#{userId}, #{targetType}, #{companyId}, #{postingId}, NOW())
    </insert>

    <!-- =====================================================
         북마크 단건 조회 (id 기준)
    ====================================================== -->
    <select id="selectBookmarkById" resultMap="BookmarkResultMap">
        SELECT id, user_id, target_type, company_id, posting_id, created_at
        FROM bookmark
        WHERE id = #{id}
    </select>

    <!-- =====================================================
         중복 체크: 유저 + 기업
    ====================================================== -->
    <select id="selectByUserAndCompany" resultMap="BookmarkResultMap">
        SELECT id, user_id, target_type, company_id, posting_id, created_at
        FROM bookmark
        WHERE user_id   = #{userId}
          AND company_id = #{companyId}
    </select>

    <!-- =====================================================
         중복 체크: 유저 + 공고
    ====================================================== -->
    <select id="selectByUserAndPosting" resultMap="BookmarkResultMap">
        SELECT id, user_id, target_type, company_id, posting_id, created_at
        FROM bookmark
        WHERE user_id   = #{userId}
          AND posting_id = #{postingId}
    </select>

    <!-- =====================================================
         북마크 목록 조회
         - COMPANY: company 테이블과 JOIN → company_name
         - POSTING: job_posting + company 테이블과 JOIN → posting_title, company_name, deadline
         created_at DESC 정렬
    ====================================================== -->
    <select id="selectBookmarksByUserId" resultMap="BookmarkResponseMap">
        SELECT b.id,
               b.target_type,
               b.company_id,
               b.posting_id,
               b.created_at,
               CASE
                   WHEN b.target_type = 'COMPANY' THEN c.name
                   WHEN b.target_type = 'POSTING' THEN pc.name
               END AS company_name,
               CASE
                   WHEN b.target_type = 'POSTING' THEN jp.title
               END AS posting_title,
               CASE
                   WHEN b.target_type = 'POSTING' THEN jp.deadline
               END AS deadline
        FROM bookmark b
                 LEFT JOIN company c  ON b.target_type = 'COMPANY' AND b.company_id = c.id
                 LEFT JOIN job_posting jp ON b.target_type = 'POSTING' AND b.posting_id = jp.id
                 LEFT JOIN company pc ON b.target_type = 'POSTING' AND jp.company_id = pc.id
        WHERE b.user_id = #{userId}
        ORDER BY b.created_at DESC
    </select>

    <!-- =====================================================
         북마크 삭제
    ====================================================== -->
    <delete id="deleteBookmark">
        DELETE FROM bookmark
        WHERE id = #{id}
    </delete>

</mapper>
