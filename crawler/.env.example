# .env.example
# application.yml 대신 Python에서는 .env 파일로 환경변수 관리
# 
# 사용법:
# 1. 이 파일을 .env로 복사: cp .env.example .env
# 2. .env 파일에 실제 값 입력
# 3. .env는 .gitignore에 등록되어 있어서 Git에 안 올라감
#
# Java에서 @Value("${spring.datasource.url}") 쓰는 것처럼
# Python에서는 pydantic-settings로 자동 주입됨

# 서버 설정
HOST=0.0.0.0
PORT=8000

# Spring Boot 연동용 (나중에 FastAPI → Spring Boot HTTP 호출 시 사용)
SPRING_BOOT_URL=http://localhost:8080

# PostgreSQL 연결 정보 (Spring Boot application.yml과 동일)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=careerfit
DB_USER=postgres
DB_PASSWORD=your_password_here

# OpenAI API (AI 분석용 — 나중에 사용)
OPENAI_API_KEY=your_openai_key_here

# 로그 레벨 (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO
